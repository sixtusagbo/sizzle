# pub ignores the .gitignore in any directory that also has a .pubignore, so
# this root file must repeat the build/tooling excludes in addition to the
# publish-only ones below. (pub does not honor .git/info/exclude at all.)

# Build and tooling artifacts
build/
.dart_tool/
.idea/
*.iml
pubspec.lock
example/pubspec.lock

# Repo-only files, not useful inside the published archive
.github/
CONTRIBUTING.md

# Example platform scaffolding: kept in the repo so the demo runs on a device,
# but excluded from the package to keep the archive small.
example/android/
example/ios/
example/web/
example/.metadata
example/.gitignore

# Third-party copyrighted design reference (also in .git/info/exclude)
1782258761032.jpeg
1782258761117.jpeg
image.png

# Internal docs, not useful to package consumers
HANDOFF.md
CLAUDE.md
